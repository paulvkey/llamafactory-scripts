#!/usr/bin/env bash

set -Eeuo pipefail

SCRIPT_PATH=${BASH_SOURCE[0]}
while [[ -L "$SCRIPT_PATH" ]]; do
  LINK_DIR=$(cd -P -- "$(dirname -- "$SCRIPT_PATH")" && pwd)
  LINK_TARGET=$(readlink -- "$SCRIPT_PATH")
  if [[ "$LINK_TARGET" == /* ]]; then
    SCRIPT_PATH=$LINK_TARGET
  else
    SCRIPT_PATH="$LINK_DIR/$LINK_TARGET"
  fi
done
SCRIPT_DIR=$(cd -P -- "$(dirname -- "$SCRIPT_PATH")" && pwd)
readonly SCRIPT_PATH SCRIPT_DIR
if [[ -r "$SCRIPT_DIR/ui.sh" ]]; then
  # Installed layout.
  # shellcheck source=../lib/ui.sh
  source "$SCRIPT_DIR/ui.sh"
else
  # Repository layout.
  # shellcheck source=../lib/ui.sh
  source "$SCRIPT_DIR/../lib/ui.sh"
fi

readonly CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/llamafactory-scripts/config"
readonly STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/llamafactory"
readonly PID_FILE="$STATE_DIR/webui.pid"
readonly LOG_FILE="$STATE_DIR/webui.log"
readonly ENDPOINT_FILE="$STATE_DIR/webui.endpoint"

INSTALL_MODE=''
SOURCE_DIR=''
CONDA_ENV_NAME='llamafactory'
CONDA_EXE=''

usage() {
  cat <<'EOF'
LlamaFactory WebUI 管理命令

用法：
  llamafactory-webui start [--gpus all|none|0,1] [--host 地址] [--port 端口] [-- WebUI参数...]
  llamafactory-webui stop
  llamafactory-webui status
  llamafactory-webui logs [-f]
  llamafactory-webui help [start|stop|status|logs]

操作：
  start    后台启动 WebUI，自动激活 llamafactory Conda 环境
  stop     停止由本命令启动的 WebUI
  status   查看 WebUI 是否正在运行及其 PID
  logs     显示最近 100 行日志；加 -f 持续跟踪
  help     显示总帮助或指定操作的帮助

帮助：
  llamafactory-webui help start
  llamafactory-webui start --help
  llamafactory-webui --help
EOF
}

show_help() {
  local topic=${1-}
  case "$topic" in
    ''|help)
      usage
      ;;
    start)
      cat <<'EOF'
用法：llamafactory-webui start [--gpus GPU] [--host 地址] [--port 端口] [-- WebUI参数...]

后台启动 LlamaFactory WebUI。启动前会自动激活安装时创建的 llamafactory Conda 环境。

选项：
  --gpus all       使用所有 NVIDIA GPU（默认）
  --gpus none      不向 WebUI 暴露 GPU，使用 CPU
  --gpus 0         仅使用 GPU 0
  --gpus 0,1       使用 GPU 0 和 GPU 1
  --host 地址      WebUI 监听地址（默认 127.0.0.1）
  --port 端口      WebUI 监听端口（默认 7860）
  -h, --help       显示此帮助

未指定 --gpus 时，交互终端会显示 GPU 型号、驱动、温度、利用率和显存占用并询问；
非交互环境默认使用全部 GPU。需要传递 WebUI 参数时，放在独立的 -- 后。

示例：
  llamafactory-webui start
  llamafactory-webui start --gpus 0,1
  llamafactory-webui start --gpus none
  llamafactory-webui start --host 0.0.0.0 --port 7860
  llamafactory-webui start --gpus 0 -- --help
EOF
      ;;
    stop)
      cat <<'EOF'
用法：llamafactory-webui stop

停止由本命令启动的 WebUI。默认发送 TERM 信号；10 秒后仍未退出则发送 KILL 信号。
EOF
      ;;
    status)
      cat <<'EOF'
用法：llamafactory-webui status

检查 PID 文件和进程启动时间，显示 WebUI 是否正在运行。
EOF
      ;;
    logs)
      cat <<EOF
用法：llamafactory-webui logs [-f]

不带参数时显示最近 100 行日志；-f 持续跟踪日志。
日志文件：$LOG_FILE
EOF
      ;;
    *)
      usage
      die "没有该帮助主题：$topic"
      ;;
  esac
}

load_config() {
  local key value
  [[ -r "$CONFIG_FILE" ]] || die "尚未安装或配置丢失，请先运行 install.sh：$CONFIG_FILE"
  while IFS='=' read -r key value; do
    case "$key" in
      INSTALL_MODE) INSTALL_MODE=$value ;;
      SOURCE_DIR) SOURCE_DIR=$value ;;
      CONDA_ENV_NAME) CONDA_ENV_NAME=$value ;;
      CONDA_EXE) CONDA_EXE=$value ;;
    esac
  done <"$CONFIG_FILE"
  [[ -d "$SOURCE_DIR" ]] || die "LlamaFactory 源码目录不存在：$SOURCE_DIR"
  [[ "$INSTALL_MODE" == conda ]] || die '安装配置无效：WebUI 启动器仅支持 Conda 安装模式。'
}

pid_identity() {
  local pid=$1 stat_line fields_after_name
  [[ -r "/proc/$pid/stat" ]] || return 1
  IFS= read -r stat_line <"/proc/$pid/stat" || return 1
  fields_after_name=${stat_line##*) }
  # starttime 是 /proc/<pid>/stat 的第 22 字段；进程名可能包含空格，需先移除前两字段。
  awk '{print $20}' <<<"$fields_after_name"
}

read_running_pid() {
  local pid saved_start current_start
  [[ -r "$PID_FILE" ]] || return 1
  read -r pid saved_start <"$PID_FILE" || return 1
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  current_start=$(pid_identity "$pid") || return 1
  [[ "$current_start" == "$saved_start" ]] || return 1
  printf '%s\n' "$pid"
}

show_gpus() {
  if ! command -v nvidia-smi >/dev/null 2>&1; then
    warn '未检测到 nvidia-smi，将使用 CPU。'
    return 1
  fi
  local rows
  rows=$(nvidia-smi --query-gpu=index,name,driver_version,temperature.gpu,utilization.gpu,memory.used,memory.total \
    --format=csv,noheader,nounits 2>/dev/null) || { warn 'nvidia-smi 查询失败，将使用 CPU。'; return 1; }
  [[ -n "$rows" ]] || { warn '未检测到 NVIDIA GPU，将使用 CPU。'; return 1; }
  printf '\n%-4s  %-30s  %-9s  %-6s  %-8s  %s\n' '编号' '型号' '驱动' '温度' '利用率' '显存 (MiB)'
  while IFS=',' read -r index name driver temp util used total; do
    index=${index//[[:space:]]/}
    name=${name#${name%%[![:space:]]*}}
    driver=${driver//[[:space:]]/}
    temp=${temp//[[:space:]]/}
    util=${util//[[:space:]]/}
    used=${used//[[:space:]]/}
    total=${total//[[:space:]]/}
    printf '%-4s  %-30.30s  %-9s  %4s°C  %6s%%  %s / %s\n' "$index" "$name" "$driver" "$temp" "$util" "$used" "$total"
  done <<<"$rows"
  printf '\n'
}

available_gpu_indexes() {
  nvidia-smi --query-gpu=index --format=csv,noheader,nounits 2>/dev/null | sed 's/[[:space:]]//g'
}

validate_gpu_selection() {
  local selection=$1 item available
  local -a selected_items
  [[ "$selection" == none ]] && return 0
  [[ "$selection" =~ ^[0-9]+(,[0-9]+)*$ ]] || return 1
  available=$(available_gpu_indexes) || return 1
  IFS=',' read -ra selected_items <<<"$selection"
  for item in "${selected_items[@]}"; do
    grep -Fxq "$item" <<<"$available" || return 1
  done
}

choose_gpus() {
  local requested=${1-} answer indexes
  if ! show_gpus >&2; then
    [[ -z "$requested" || "$requested" == all || "$requested" == none ]] || die "系统中没有可选的 NVIDIA GPU：$requested"
    printf '%s' ''
    return
  fi
  indexes=$(available_gpu_indexes | paste -sd, -)
  if [[ -n "$requested" ]]; then
    answer=$requested
  elif [[ -t 0 ]]; then
    answer=$(ask '选择 GPU（all、none 或逗号分隔编号）' all)
  else
    answer=all
  fi
  [[ "$answer" == all ]] && answer=$indexes
  validate_gpu_selection "$answer" || die "GPU 选择无效：$answer"
  [[ "$answer" == none ]] && answer=''
  printf '%s' "$answer"
}

validate_host() {
  local host=$1
  [[ -n "$host" && "$host" != *[[:space:]/]* ]]
}

validate_port() {
  local port=$1
  [[ "$port" =~ ^[0-9]+$ ]] && ((10#$port >= 1 && 10#$port <= 65535))
}

port_is_listening() {
  local host=$1 port=$2 probe_host=$1
  [[ "$host" == 0.0.0.0 || "$host" == :: ]] && probe_host=127.0.0.1
  bash -c 'exec 3<>/dev/tcp/"$1"/"$2"' _ "$probe_host" "$port" 2>/dev/null
}

show_access_info() {
  local host=$1 port=$2 server_name
  if [[ "$host" == 127.0.0.1 || "$host" == localhost ]]; then
    info "服务器本机访问地址：http://127.0.0.1:$port/"
    if [[ -n ${SSH_CONNECTION:-} ]]; then
      server_name=$(hostname -f 2>/dev/null || hostname)
      info '当前是 SSH 会话；你自己电脑浏览器中的 127.0.0.1 并不是这台服务器。'
      info "请在自己电脑另开终端执行：ssh -N -L $port:127.0.0.1:$port $USER@$server_name"
      info "然后在自己电脑打开：http://127.0.0.1:$port/"
    fi
  elif [[ "$host" == 0.0.0.0 || "$host" == :: ]]; then
    warn 'WebUI 已监听所有网络接口，请确认防火墙和访问权限，并避免暴露到不可信网络。'
    info "访问地址：http://<服务器IP>:$port/"
  else
    info "访问地址：http://$host:$port/"
  fi
}

start_webui() {
  local requested_gpus='' host=127.0.0.1 port=7860 gpu_selection pid start_time attempt
  local -a webui_args=()
  while (($#)); do
    case "$1" in
      --gpus)
        (($# >= 2)) || die '--gpus 缺少参数。'
        requested_gpus=$2
        shift 2
        ;;
      --host)
        (($# >= 2)) || die '--host 缺少参数。'
        host=$2
        shift 2
        ;;
      --port)
        (($# >= 2)) || die '--port 缺少参数。'
        port=$2
        shift 2
        ;;
      --)
        shift
        webui_args+=("$@")
        break
        ;;
      -h|--help)
        show_help start
        return
        ;;
      *) die "未知参数：$1（WebUI 参数请放在 -- 后）" ;;
    esac
  done
  validate_host "$host" || die "监听地址无效：$host"
  validate_port "$port" || die "监听端口无效：$port（应为 1-65535）"
  if pid=$(read_running_pid); then
    die "WebUI 已在运行（PID $pid）。"
  fi
  rm -f -- "$PID_FILE" "$ENDPOINT_FILE"
  mkdir -p "$STATE_DIR"
  gpu_selection=$(choose_gpus "$requested_gpus")
  port_is_listening "$host" "$port" && die "端口 $port 已被占用，请停止占用进程或使用 --port 指定其他端口。"

  step '启动 LlamaFactory WebUI'
  local conda_base conda_sh
  [[ -x "$CONDA_EXE" ]] || die "Conda 不可执行：$CONDA_EXE"
  conda_base=$("$CONDA_EXE" info --base)
  conda_sh="$conda_base/etc/profile.d/conda.sh"
  [[ -r "$conda_sh" ]] || die "找不到 Conda 初始化脚本：$conda_sh"
  nohup bash -c 'source "$1"; conda activate "$2"; cd "$3"; shift 3; exec env "CUDA_VISIBLE_DEVICES=$1" "GRADIO_SERVER_NAME=$2" "GRADIO_SERVER_PORT=$3" llamafactory-cli webui "${@:4}"' \
    _ "$conda_sh" "$CONDA_ENV_NAME" "$SOURCE_DIR" "$gpu_selection" "$host" "$port" "${webui_args[@]}" >>"$LOG_FILE" 2>&1 &
  pid=$!
  for attempt in {1..30}; do
    if ! kill -0 "$pid" 2>/dev/null; then
      error 'WebUI 启动失败，最近日志：'
      tail -n 50 "$LOG_FILE" >&2
      exit 1
    fi
    port_is_listening "$host" "$port" && break
    sleep 0.5
  done
  start_time=$(pid_identity "$pid") || die '无法记录 WebUI 进程状态。'
  printf '%s %s\n' "$pid" "$start_time" >"$PID_FILE"
  printf '%s %s\n' "$host" "$port" >"$ENDPOINT_FILE"
  success "WebUI 已启动（PID $pid，CUDA_VISIBLE_DEVICES=${gpu_selection:-<CPU>}）。"
  if port_is_listening "$host" "$port"; then
    success "WebUI 已监听端口：$port"
  else
    warn "进程仍在运行，但等待 15 秒后端口 $port 尚未监听，可能仍在初始化。"
    warn '请执行 llamafactory-webui logs 查看启动日志。'
  fi
  show_access_info "$host" "$port"
  info "如需在当前终端使用 LlamaFactory CLI，请执行：conda activate $CONDA_ENV_NAME"
  info "日志：$LOG_FILE"
}

stop_webui() {
  local pid attempt
  if ! pid=$(read_running_pid); then
    rm -f -- "$PID_FILE" "$ENDPOINT_FILE"
    warn 'WebUI 未运行。'
    return
  fi
  step "停止 LlamaFactory WebUI（PID $pid）"
  kill -TERM "$pid"
  for attempt in {1..20}; do
    kill -0 "$pid" 2>/dev/null || break
    sleep 0.5
  done
  if kill -0 "$pid" 2>/dev/null; then
    warn '进程未在 10 秒内退出，发送 KILL 信号。'
    kill -KILL "$pid"
  fi
  rm -f -- "$PID_FILE" "$ENDPOINT_FILE"
  success 'WebUI 已停止。'
}

status_webui() {
  local pid host port
  if pid=$(read_running_pid); then
    success "WebUI 正在运行（PID $pid）。"
    if [[ -r "$ENDPOINT_FILE" ]] && read -r host port <"$ENDPOINT_FILE"; then
      if port_is_listening "$host" "$port"; then
        success "端口 $port 正在监听。"
      else
        warn "进程存在，但端口 $port 尚未监听。"
      fi
      show_access_info "$host" "$port"
    fi
    info "日志：$LOG_FILE"
  else
    warn 'WebUI 未运行。'
    return 1
  fi
}

show_logs() {
  [[ -e "$LOG_FILE" ]] || die "日志文件尚不存在：$LOG_FILE"
  if [[ ${1-} == -f ]]; then
    tail -f "$LOG_FILE"
  else
    [[ $# -eq 0 ]] || die 'logs 仅支持 -f 参数。'
    tail -n 100 "$LOG_FILE"
  fi
}

main() {
  local command_name action
  command_name=$(basename -- "$0")
  case "$command_name" in
    *-start) action=start ;;
    *-stop) action=stop ;;
    *) action=${1:-}; [[ $# -gt 0 ]] && shift ;;
  esac
  case "$action" in
    help) show_help "${1-}"; return 0 ;;
    -h|--help|'') show_help; return 0 ;;
  esac
  if [[ ${1-} == -h || ${1-} == --help ]]; then
    show_help "$action"
    return 0
  fi
  load_config
  case "$action" in
    start) start_webui "$@" ;;
    stop) stop_webui ;;
    status) status_webui ;;
    logs) show_logs "$@" ;;
    *) usage; die "未知操作：$action" ;;
  esac
}

main "$@"
